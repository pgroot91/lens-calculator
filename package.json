{
  "name": "lens-calculator",
  "version": "3.0.0",
  "description": "A WordPress plugin to calculate lens sizes for various applications.",
  "type": "module",
  "license": "GPL-2.0-or-later",
  "author": "Patrick Groot",
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@cypress/code-coverage": "^4.0.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@wordpress/env": "^11.7.0",
    "babel-jest": "^30.4.1",
    "babel-plugin-istanbul": "^8.0.0",
    "cross-env": "^10.1.0",
    "cypress": "^15.16.0",
    "grunt": "^1.6.2",
    "grunt-wp-i18n": "^1.0.4",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "npm-run-all": "^4.1.5",
    "vite": "^8.0.14",
    "vite-plugin-istanbul": "^9.0.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "makepot": "npx grunt makepot",
    "prepare": "husky",
    "env:start": "wp-env start",
    "env:clean": "wp-env clean",
    "env:destroy": "wp-env destroy",
    "env:stop": "wp-env stop",
    "env:start:dev": "wp-env start --env=development",
    "env:start:test": "wp-env start --env=tests",
    "cy:open:launch:dev": "cypress open -b chrome --config-file cypress.config.dev.cjs",
    "cy:run:launch:dev": "cypress run -b chrome --config-file cypress.config.dev.cjs",
    "cy:open:launch:test": "cypress open -b chrome --config-file cypress.config.test.cjs",
    "cy:run:launch:test": "cypress run -b chrome --config-file cypress.config.test.cjs",
    "cy:open:dev": "run-s env:destroy env:start:dev cy:open:launch:dev",
    "cy:run:dev": "run-s env:destroy env:start:dev cy:run:launch:dev",
    "cy:open:test": "run-s env:destroy env:start:test cy:open:launch:test",
    "cy:run:test": "run-s env:destroy env:start:test cy:run:launch:test",
    "test:php": "wp-env run --env-cwd='wp-content/plugins/lens-calculator/' tests-cli vendor/bin/phpunit -c phpunit.xml --testdox --verbose --coverage-text --coverage-html coverage/php",
    "test:js": "jest --config=jest.config.cjs --coverage"
  }
}
